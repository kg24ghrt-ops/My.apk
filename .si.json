{
  "plugin": "org.smartide.plugin.editor",
  "run": "echo 'change command from .si.json file'",
  "gui": false,
  "intelligence": {
    ".yml": {
      "enabled": true,
      "run": "yaml-language-server --stdio"
    },
    ".gradle": {
      "enabled": true,
      "run": "groovy-language-server"
    },
    ".json": {
      "enabled": true,
      "run": "vscode-json-language-server --stdio"
    },
    ".properties": {
      "enabled": true,
      "run": "lemminx"
    }
  }
}